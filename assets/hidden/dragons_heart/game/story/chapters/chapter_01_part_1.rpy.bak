default ch1_choice_1_done = False
default ch1_choice_2_done = False
default ch1_choice_3_done = False
default ch1_choice_4_done = False
default ch1_current_choice = 0


label chapter_01_part_1:
    # Placeholder for Tiano Dorian's Room (missing BG asset by design).
    scene bg black_background with long_fade
    show bg black_background at bg_focus_clear
    pause 0.2
    show bg black_background at bg_focus_blur, dim_scene with Dissolve(0.2)
    play ambience "audio/ambience/city_ambience_1.ogg"

    show dorian serious at top:
        xoffset 340
        breathing
    show elara neutral at top:
        xoffset -340
        breathing
    with dissolve

    elara "{cps=30}Tianho... Tetrad above... It's even more beautiful than the stories."
    elara "{cps=30}Dorian, we should take the kids to see the market! Lucas is going to love this!"

    $ narr("I exhale a slow breath, watching the evening lights bathe the city of Tianho through my binoculars, reflecting off the rivers that weave through its heart like threads of silver.")
    $ narr("The air smells of spiced tea and roasted chestnuts from the market stalls below, mingling with the faint fragrance of cherry blossoms that line the cobblestone streets.")
    $ narr("The streets below are bustling with life, lined with towering pagodas adorned in colors of crimson, gold, and jade. Lanterns of every imaginable hue float above the streets, their light glowing softly.")

    elara "{cps=30}Dorian. Are you even listening to me? You've been standing there for a while now."

    show dorian serious at top:
        xoffset 340
        toggle_flip
        listening_focus
        breathing

    $ narr("I turn to face her, sighing as I pocket my binoculars. She's leaning against the doorframe, arms crossed, a wry smile playing on her lips.")

    elara "{cps=30}You've been standing there long enough to memorize every single detail of the city. Meanwhile, the children are pestering me about seeing the nighttime lantern markets."
    elara "{cps=30}I would very much like my HUSBAND to take me there as soon as possible before he vanishes to work tomorrow."

    $ narr("I sigh, turning back to the view.")

    show dorian serious at top:
        xoffset 340
        speaking_focus
        breathing
    dorian "{cps=30}My heart, you know how important tomorrow is. Everything has to be perfect."

    $ narr("She sighs.")

    elara "{cps=30}I know, Dorian. I know how important it is. The entire world will be watching as Kyeongjang's emperor makes his first public appearance in centuries."
    dorian "{cps=30}For centuries, Kyeongjang was nothing more than a legend. Many doubted it even existed, and now, their emperor is emerging from the shadows to reconnect."
    dorian "{cps=30}This meeting isn't just a reunion-it's a turning point. Alliances will shift. Trade will flourish-or collapse. Power balances will be rewritten."
    dorian "{cps=30}And you know Her Majesty. She won't settle for anything less than perfection."

    $ narr("Elara steps closer, her soft smile returning. She reaches up and brushes her fingertips against my cheek.")

    elara "{cps=30}And you, sir Dorian. You're part of that perfection, aren't you? The Dragon of Gale, second only to the High Paladin himself. You'll make sure it all goes smoothly, like you always do."
    $ narr("I manage a faint smile, but the tension in my chest doesn't ease. She notices, of course. She always does.")

    elara "{cps=30}But, my heart. That's tomorrow. Tomorrow is for the world, the king and the empress and the emperor and their grand, history-altering plans. But tonight?"
    $ narr("She steps even closer, giving my cheek a kiss.")
    elara "{cps=30}Tonight, you're not the Dragon of Gale. You're not a paladin. You're my husband. And the father of four wonderful, slightly rambunctious children who are dying to explore this incredible city."

    dorian "{cps=30}But, my heart..."
    elara "{cps=30}No excuses, my heart. You've been working tirelessly ever since we left Gale. Tonight is for us. For me. For the kids who adore their father. For a family that rarely gets days like this together."

    show dorian smile at top:
        xoffset 340
        speaking_focus
        breathing
    $ narr("I sigh, a small smile finally breaking through my resolve. I kissed her.")
    dorian "{cps=30}Alright, my heart. You win."

    $ narr("She returns my kiss, but only briefly as she quickly pulls away. She grabs my hand and pulls me toward the door, her laughter filling the balcony.")
    elara "{cps=30}Come on, Dragon of Gale. The lantern markets won't wait, and neither will the kids!"

    scene bg tiangho_city_night_proper with slow_dissolve
    show bg tiangho_city_night_proper at bg_focus_clear
    pause 0.2
    show bg tiangho_city_night_proper at bg_focus_blur, dim_scene with Dissolve(0.2)
    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    with dissolve

    $ narr("The moment we step out into the street, the kids swarm us, buzzing with excitement.")

    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Dad! Dad! Look! Look at all the people! This place is huge!"
    $ narr("Lucas' eyes are open wide as he keeps tugging at the hem of my tunic with both hands.")

    hide lucas_kid
    hide daniel_kid
    hide emily_kid
    hide sarah_kid
    show dorian neutral at top:
        xoffset 220
        toggle_flip
        speaking_focus
        breathing
    show elara neutral at top:
        xoffset -220
        listening_focus
        breathing
    with dissolve
    dorian "{cps=30}Yes, it is. But remember what I said-stay close, okay?"

    show dorian neutral at top:
        xoffset 220
        listening_focus
        breathing
    show elara neutral at top:
        xoffset -220
        speaking_focus
        breathing
    $ narr("Sarah, as expected, is lost in her own world, flipping through her sketchbook and occasionally glancing up to capture the essence of the city in her drawings.")
    elara "{cps=30}Sarah... Sarah... Honey. *snaps her fingers* Your father is here."

    hide dorian
    hide elara
    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    with dissolve

    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah "{cps=30}*mumbles* Oh, hey dad!"
    $ narr("She glances quickly at me, smiles, then turns back, completely absorbed in her art.")
    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah "{cps=30}This place is full of colors. I need to capture the lanterns. But, I don't know what color they should be..."

    $ narr("Emily leans over to Daniel and whispers something in his ear, making him roll his eyes but smirk at the same time.")
    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        speaking_focus
        breathing
    emily "{cps=30}Come on, Daniel! You have to at least pretend to be excited!"
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}Hey, I am excited! Just not the way you are."

    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing

    hide lucas_kid
    hide daniel_kid
    hide emily_kid
    hide sarah_kid
    show dorian neutral at top:
        xoffset 220
        speaking_focus
        breathing
    show elara neutral at top:
        xoffset -220
        listening_focus
        breathing
    with dissolve

    dorian "{cps=30}Come on, kids. We're going to the market."

    show dorian neutral at top:
        xoffset 220
        listening_focus
        breathing
    show elara neutral at top:
        xoffset -220
        speaking_focus
        breathing
    elara "{cps=30}But stay close to your father and me. Tianho may be beautiful, but-"

    hide dorian
    hide elara
    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        speaking_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    with dissolve

    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        speaking_focus
        breathing
    emily "{cps=30}You never know what lurks beneath the hearts of strangers and how we kids are gullible and-"
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}We know that, mom! Stranger Danger a thousand times. Can we just hurry up? I wanna see some dragons."

    $ narr("Sarah finally closes her sketchbook, tucking it under her arm.")
    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah "{cps=30}Mom, we need to see the dragons!"

    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing

    hide lucas_kid
    hide daniel_kid
    hide emily_kid
    hide sarah_kid
    show elara neutral at top:
        xoffset -220
        speaking_focus
        breathing
    with dissolve

    elara "{cps=30}Alright, alright. Let's go see them. But remember, no pretending to be dragons."
    kids_bottom "{cps=30}Yes, mom."

    $ narr("With that, the children take off ahead of us, their chatter and laughter blending into the sounds of the city.")
    $ narr("Elara walks beside me and I hold her hand.")

    show elara neutral at top:
        xoffset -220
        speaking_focus
        breathing
    elara "{cps=30}So, where should we go first?"

    show elara neutral at top:
        xoffset -220
        listening_focus
        breathing
    show dorian neutral at top:
        xoffset 220
        speaking_focus
        breathing
    dorian "{cps=30}Well, all of the kids seem intent on finding dragons, and you say that you want to eat at the stalls. I say we follow the flow of the crowd and see where it takes us."

    show dorian neutral at top:
        xoffset 220
        listening_focus
        breathing
    show elara neutral at top:
        xoffset -220
        speaking_focus
        breathing
    $ narr("Elara nods, her eyes sparkling with the same excitement I see in the children.")
    elara "{cps=30}Sounds like a plan. But don't think you're getting off easy, Dragon of Gale. You're carrying the bags."

    show elara neutral at top:
        xoffset -220
        listening_focus
        breathing
    show dorian neutral at top:
        xoffset 220
        speaking_focus
        breathing
    dorian "{cps=30}Of course, I am."

    $ narr("As we move deeper into the marketplace, the city seems to come alive around us. Elara looks at me, her hand still in mine, while the kids fidget and bounce with anticipation.")
    $ narr("We can go to Deng Blossom Avenue, where the lanterns for tomorrow are being prepared. There is also the Fanrong Dragon Square, where the rehearsals for tomorrow's Dragon Dances are being held.")
    $ narr("I can also bring them to the Xiangli Centre, where the food stalls are. Or maybe I can lead them straight to the Zhong Lotus Promenade, where inventors are showcasing their inventions for a chance to speak to the Kyeongjang Emperor himself.")
    $ narr("Either way, we're still going to the Zhong Lotus Promenade. Maybe I can take them to the other places first.")
    $ narr("I glance at Elara, who's watching the children with an amused smile as they eagerly debate where to go first. She meets my eyes and tilts her head slightly.")

    show dorian neutral at top:
        xoffset 220
        listening_focus
        breathing
    show elara neutral at top:
        xoffset -220
        speaking_focus
        breathing
    elara "{cps=30}Well, my heart, you're the Father. What'll it be? The kids can't wait."

    hide dorian
    hide elara
    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    with dissolve

    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Hurry up, dad!"

    $ narr("Where should we go?")

    call chapter_01_choice_hub
    return


label chapter_01_choice_hub:
    menu:
        "Deng Blossom Avenue (The Lanterns)" if ch1_current_choice != 1:
            jump chapter_01_choice_1

        "Fanrong Dragon Square (The Dragon Dance Rehearsals)" if ch1_current_choice != 2:
            jump chapter_01_choice_2

        "Xiangli Centre (Food Stalls)" if ch1_current_choice != 3:
            jump chapter_01_choice_3

        "Zhong Lotus Promenade (The Inventors)" if ch1_current_choice != 4:
            jump chapter_01_choice_4


label chapter_01_choice_1:
    if ch1_choice_1_done:
        $ ch1_current_choice = 1
        $ narr("We have nothing to do here anymore.")
        jump chapter_01_choice_hub

    $ ch1_choice_1_done = True
    $ ch1_current_choice = 1

    # Placeholder for missing Deng Blossom background.
    scene bg black_background with dissolve
    show bg black_background at bg_focus_clear
    pause 0.2
    show bg black_background at bg_focus_blur, dim_scene with Dissolve(0.2)

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    with dissolve

    $ narr("We turn toward Deng Blossom Avenue, a decision met with a satisfied hum from Sarah and nods of approval from the others.")
    $ narr("The moment we step onto the avenue, lanterns-hundreds, perhaps thousands of them-float effortlessly in the air, their glow soft and ethereal.")
    $ narr("They seem alive, swaying gently as though in sync with the faint breeze that carries the sweet scent of lotus blossoms and jasmine.")

    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}Look! They're moving!"

    $ narr("He points upward as a line of lanterns sweeps across the avenue, almost like a school of fish in the sea.")

    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Are they alive? How are they doing that?"

    elara "{cps=30}It's breathtaking."
    dorian "{cps=30}It is, my heart."

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah "{cps=30}Oh gosh! This is so beautiful! The colors... I need to get the colors just right!"
    sarah "{cps=30}But how do I even start? The reds aren't just red-they're ruby, garnet, scarlet-oh, this is impossible!"

    dorian "{cps=30}Take your time, Sarah. The lanterns aren't going anywhere."

    $ narr("Lucas points to a massive lantern shaped like a koi fish.")

    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Dad look! That lantern's huge!"

    $ narr("He darts forward to get a better look. I quickly grab his hand.")

    dorian "{cps=30}Careful, Lucas. Stay close."

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}How do they even make those?"

    dorian "{cps=30}With bamboo and silk, Daniel."

    # Fire channelers intentionally have no sprites in this scene.
    lead_fire_channeler "{cps=30}Alright, that's enough! Bring them back, fire channelers!"

    $ narr("A group of figures in crimson robes steps into view at the far end of the avenue, their hands raised in precise, fluid motions. Flames flicker in their palms.")
    $ narr("One by one, the lanterns return to the fire channelers, floating gently into their hands like obedient birds.")

    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        speaking_focus
        breathing
    emily "{cps=30}Dad! They're making them come back!"
    emily "{cps=30}Dad, you're a fire channeler right? Can you make the lanterns move like that?"

    dorian "{cps=30}Of course, Emily."

    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}That's a stupid question, Emily! Dad's the strongest!"

    elara "{cps=30}Shh! Daniel, watch your words or you'll be heading back to our room at the inn!"

    $ narr("All of us watch intently as the last lantern disappears into the robes of the fire channelers.")

    lead_fire_channeler "{cps=30}This is just a rehearsal. Tomorrow, we'll perform before the Emperor of Kyeongjang himself. We better bring our A game."
    channelers "{cps=30}Sir!"

    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah "{cps=30}I'm done!"

    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}Really? Lemme see!"

    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah "{cps=30}Later, Daniel! I'll show it once I place some finishing touches! *giggles*"

    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Let's go somewhere else, Dad!"

    $ ch1_current_choice = 1
    jump chapter_01_choice_hub


label chapter_01_choice_2:
    if ch1_choice_2_done:
        $ ch1_current_choice = 2
        $ narr("We have nothing to do here anymore.")
        jump chapter_01_choice_hub

    $ ch1_choice_2_done = True
    $ ch1_current_choice = 2

    # Placeholder for missing Fanrong Dragon background.
    scene bg black_background with dissolve
    show bg black_background at bg_focus_clear
    pause 0.2
    show bg black_background at bg_focus_blur, dim_scene with Dissolve(0.2)

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    with dissolve

    $ narr("I decided that we will go to Fanrong Dragon Square to watch the Dragon dance rehearsals.")
    $ narr("As we arrive, we find that the square is alive with rhythm and energy, the pounding of drums and clanging of cymbals echoing off the towering pagodas.")
    $ narr("Brightly colored dragons-red, gold, and violet-twist and coil through the crowd, their movements fluid yet deliberate, each step in perfect harmony with the beat of the music.")
    $ narr("It was apparent that the performers have been rehearsing tirelessly, their focus palpable as they prepare for tomorrow's grand event.")
    $ narr("The children are immediately enthralled. Lucas tugs on my tunic and points with both hands, his voice filled with awe.")

    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Look at them, Dad! It's a real dragon!"

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah "{cps=30}Mom! Dad! It's the Prosperity Dragon!"

    dorian "{cps=30}Yeah... The Prosperity Dragon..."

    $ narr("Lucas can't contain himself. His arms flail as he mimics the twisting, serpentine motions of the dragon dancers, his tiny legs stomping a rhythm of their own on the cobblestone square.")
    $ narr("Sarah joins in, her movements more graceful, while Daniel smirks and crosses his arms, clearly too cool to dance but not immune to the energy.")

    dorian "{cps=30}Careful, kids. You'll wear yourselves out before we even explore the rest of the city."

    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}I never get tired, Dad."

    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        speaking_focus
        breathing
    emily "{cps=30}Daniel, please..."

    $ narr("As we step closer to the rehearsal, I notice some of the dragon dancers stealing glances in our direction. Whispers ripple through their group, and I catch snippets of their murmurs.")

    # Nervous performers intentionally have no sprites in this scene.
    nervous_performer_1 "{cps=30}It's him... The Dragon of Gale..."
    nervous_performer_2 "{cps=30}Is he watching us? Oh no, my steps are all wrong!"
    nervous_performer_3 "{cps=30}Do you think he'll criticize us?"
    nervous_performer_1 "{cps=30}C-Calm down, you guys. He might report us to the Empress!"

    $ narr("One of the performers, a young man holding the golden dragon's head, stumbles slightly, his confidence clearly shaken. He regains his footing quickly, but his face is flushed with embarrassment.")

    dorian "{cps=30}You're doing well. Keep your movements calm and deliberate. The Prosperity Dragon commands respect, not chaos."

    nervous_performer_2 "{cps=30}Th-thank you, sir. We're... we're just nervous, you see. Tomorrow's performance is for the Emperor of Kyeongjang, the King of Tianho, and, of course, Empress Olympia."
    nervous_performer_3 "{cps=30}We're just very nervous... Our dance, we just want it to be perfect."

    $ narr("His words carry a weight I understand all too well.")

    dorian "{cps=30}You'll be fine. Focus on your training, not the audience."
    channelers "{cps=30}Sir!"

    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Can I try to be a dragon, Dad? Please? I want to be a dragon too!"

    $ narr("Lucas runs to Daniel, making sweeping motions with his hands.")

    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Look at me! I'm the Dragon of Gale! Rwarrr!!"

    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        speaking_focus
        breathing
    emily "{cps=30}Roaaarr!!! Look, Dad! I can do it too!"

    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}I could totally play the drums better than that guy."

    elara "{cps=30}Kids, calm down. My heart, maybe we should move on before they start asking to join the rehearsal."
    dorian "{cps=30}Alright, let's head somewhere else."

    nervous_performer_1 "{cps=30}Thank you for your encouragement. We'll make sure tomorrow's performance is flawless!"
    dorian "{cps=30}I'm sure you will."

    $ narr("As we walk away, Elara links her arm through mine.")

    elara "{cps=30}That was nice of you, you know. Giving them a little confidence boost."
    dorian "{cps=30}It's the least I could do."

    $ narr("I reply, glancing back at the square one last time. The beat of the drums fades behind us.")

    $ ch1_current_choice = 2
    jump chapter_01_choice_hub


label chapter_01_choice_3:
    if ch1_choice_3_done:
        $ ch1_current_choice = 3
        $ narr("We have nothing to do here anymore.")
        jump chapter_01_choice_hub

    $ ch1_choice_3_done = True
    $ ch1_current_choice = 3

    scene bg tianho_celeb_food_stalls with dissolve
    show bg tianho_celeb_food_stalls at bg_focus_clear
    pause 0.2
    show bg tianho_celeb_food_stalls at bg_focus_blur, dim_scene with Dissolve(0.2)

    $ narr("I decided to take the family out for dinner at the stalls at Xiangli Centre.")
    $ narr("My family surges ahead, the kids' excitement pulling me along like a tide. Lanterns strung overhead illuminate the bustling food stalls, casting everything in a warm, golden glow.")

    scene bg 11_family_foodstalls with dissolve
    show bg 11_family_foodstalls at bg_focus_clear
    pause 0.2

    elara "{cps=30}Come on, Dorian. Even you can't resist this."

    scene bg tianho_celeb_food_stalls with dissolve
    show bg tianho_celeb_food_stalls at bg_focus_clear
    pause 0.2
    show bg tianho_celeb_food_stalls at bg_focus_blur, dim_scene with Dissolve(0.2)

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    with dissolve

    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Dad! They've got... uh... what are these?"

    dorian "{cps=30}Those are Tianho's famous \"Spring Bite Skewers.\" Roasted jian yan chun shi, Lucas."

    show expression "images/food/FOOD1.png" as food_focus at truecenter with dissolve

    $ narr("The vendor laughs, lifting a skewer of the food. Each skewer has bite-sized pieces of meat glazed in a tangy-sweet sauce, interspersed with charred fruit slices and crispy greens. Lucas' mouth hangs open as he stares at it.")

    vendor "{cps=30}Tianho's finest! Would you like to have some?"

    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas_bottom "{cps=30}Yes please! Yes please!"

    hide food_focus with dissolve

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        speaking_focus
        breathing
    emily "{cps=30}I want some! I want some!"

    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}Hey! I'm older than you, Lucas! I should have one before you!"

    $ narr("Sarah closes her sketchbook and quickly grabs a seat.")

    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah "{cps=30}I suppose having one won't hurt me."

    elara "{cps=30}I'll be getting seconds hehe. You know me, my heart."
    dorian "{cps=30}We'll get ten."

    $ narr("I nod to the vendor as I hand him a few coins. The vendor freezes, his eyes widening as he speaks.")

    vendor "{cps=30}Merciful Tetrad! P-Paladin Dorian! I apologize."

    $ narr("He stammers, nearly dropping the skewer in his hand.")

    vendor "{cps=30}P-Please, my lord, I couldn't possibly charge you. The food is yours-no payment needed!"
    dorian "{cps=30}*sighs* Just take it. Please."

    $ narr("There's a brief pause before the vendor relents, nodding gratefully and motioning for us to sit.")

    vendor "{cps=30}As you wish, Paladin. Please, take a seat. I'll serve your family the best this night has to offer."

    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Ow! Ow! It's hot! Hot hot hot!"

    elara "{cps=30}Lucas. It's the fifth time this month you burnt your tongue!"

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        speaking_focus
        breathing
    emily "{cps=30}Haha! Lucas burnt his tongue again!"

    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah "{cps=30}Emily, you're one to talk! You kept burning your tongue last year!"

    $ narr("The vendor gives us steaming bowls of long xin tang-\"Dragon Heart Soup.\" The broth is deep red, spicy and rich, with delicate dumplings shaped like dragon scales floating on top.")
    $ narr("The bowls arrive in a rush, and we dive in before the steam has fully settled.")

    dorian "{cps=30}This one's delicious. Long xin tang. You're going to love it."

    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}This is so spicy! Mom, try it!"

    $ narr("He shoves the bowl toward Elara, who takes a dainty sip.")

    elara "{cps=30}Wow, that has a kick."

    show expression "images/food/FOOD3.png" as food_focus at truecenter with dissolve

    $ narr("Meanwhile, Sarah picks at a plate of zhu ye ping gao-\"Bamboo Crystal Cakes.\" The translucent, jelly-like squares shimmer under the lantern light, filled with bursts of fruit and a faintly sweet flavor.")
    $ narr("She sketches the cakes in her notebook before taking a single, careful bite.")

    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah_bottom "{cps=30}Oh my! It's like eating a jewel!"

    hide food_focus with dissolve

    $ narr("Just as I'm starting to enjoy myself, a voice breaks through the din of the market.")

    hide lucas_kid
    hide daniel_kid
    hide emily_kid
    hide sarah_kid
    with dissolve

    soldier_1 "{cps=30}Paladin Dorian!"

    show soldier_gao neutral at truecenter:
        listening_focus
        breathing
    with dissolve

    $ narr("I turn to see three soldiers in Tianho's imperial armor weaving through the crowd. They salute sharply as they reach me.")

    soldier_1 "{cps=30}Paladin! Apologies for the interruption."
    dorian "{cps=30}At ease, soldiers. What is it?"

    male_soldier_2 "{cps=30}The perimeter reports for the event tomorrow, sir. We wanted to ensure you were informed."

    show soldier_gao neutral at truecenter:
        speaking_focus
        breathing
    soldier_gao "{cps=30}Paladin, we were hoping you might join us for a quick assessment. Your presence would be... reassuring."

    $ narr("I feel Elara's eyes on me, and when I glance her way, she's arching a single eyebrow.")

    dorian "{cps=30}Can it wait until morning?"
    male_soldier_1 "{cps=30}Of course, sir. We didn't mean to disrupt your evening."
    dorian "{cps=30}Good. Keep me updated."

    hide soldier_gao with dissolve

    $ narr("The soldiers bow slightly before disappearing back into the crowd. I turn back to my family, only to find Daniel mimicking the soldiers. He salutes dramatically, puffing out his chest.")

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    with dissolve

    daniel "{cps=30}Paladin Dorian, sir!"

    hide lucas_kid
    hide daniel_kid
    hide emily_kid
    hide sarah_kid
    show dorian neutral at top:
        xoffset 220
        listening_focus
        breathing
    show elara neutral at top:
        xoffset -220
        speaking_focus
        breathing
    with dissolve

    elara "{cps=30}Oh, Daniel. You'll make a fine soldier one day."

    show elara neutral at top:
        xoffset -220
        listening_focus
        breathing
    show dorian neutral at top:
        xoffset 220
        speaking_focus
        breathing
    dorian "{cps=30}Alright. Let's continue exploring."

    $ ch1_current_choice = 3
    jump chapter_01_choice_hub


label chapter_01_choice_4:
    if ch1_choice_4_done:
        $ ch1_current_choice = 4
        $ narr("We've already wrapped up for tonight.")
        return

    $ ch1_choice_4_done = True
    $ ch1_current_choice = 4

    # Placeholder for missing Zhong Lotus Promenade background.
    scene bg tiangho_city_night_proper with dissolve
    show bg tiangho_city_night_proper at bg_focus_clear
    pause 0.2
    show bg tiangho_city_night_proper at bg_focus_blur, dim_scene with Dissolve(0.2)

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    with dissolve

    $ narr("We stroll down Zhong Lotus Promenade, where the air hums with the clinking of metal, the hiss of steam, and the occasional outburst of an overly enthusiastic inventor.")
    $ narr("Sarah slows down, sketchbook in hand, capturing the finer details of the pagodas surrounding the promenade. Meanwhile, Lucas is giggling at a toy soldier marching in uneven, jerky steps, as if it's had one too many cups of tea.")
    $ narr("As we walk further, Daniel suddenly stops, eyes lighting up as he points to a large wooden sign adorned with intricate calligraphy: \"EXHIBIT OF FUTURE INNOVATIONS - INSPIRED BY THE KYEONGJANG EMPIRE!\"")

    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}The Empire of Kyeongjang?"

    dorian "{cps=30}Yeah, I forgot to mention. They're doing an exhibit inspired by mythical advanced technology of the Hidden Empire of Kyeongjang."

    $ narr("It's an opportunity for local inventors to showcase their creations, with the winner receiving the honor of speaking directly to the Emperor of Kyeongjang during tomorrow's historic meeting.")
    $ narr("The thought alone makes me pause-Kyeongjang, the most advanced civilization this world has seen in 400 years, reconnecting with us at last.")
    $ narr("The Emperor of Kyeongjang, a living legend, would only entertain the most brilliant minds.")

    dorian "{cps=30}They're longing for a chance to showcase their technological advancement to the Emperor."

    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}Tetrad above! We have to see it, dad! Think of all the science we can see!"

    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah "{cps=30}Hey! I thought you hated science!"

    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Yeah! Remember the time you called me a dork for picking up a science book?"

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        speaking_focus
        breathing
    daniel "{cps=30}I, um... Well..."

    elara "{cps=30}All right, kids. Settle down. Let's just look at the exhibits."

    $ narr("I smile at her and gesture for the kids to follow me to the exhibit.")
    $ narr("The exhibit area is packed with people. At the center is a small stage, where a young man with wild, unkempt hair and smudges of soot on his face is gesturing grandly to the crowd. His robes are slightly singed, and his eyebags were... apparent.")

    hide lucas_kid
    hide daniel_kid
    hide emily_kid
    hide sarah_kid
    with dissolve

    show yuxuan happy at truecenter:
        speaking_focus
        breathing
    with dissolve

    yuxuan "{cps=30}Ladies and gentlemen! My name is Cheng Yuxuan, an aspiring visionary inventor! Thank you for coming to my humble exhibit!"

    $ narr("With a dramatic flourish, he pulls a sad piece of red fabric off a large, boxy contraption.")
    $ narr("It's... well, it's a square metal box with arms made of mismatched pipes and legs that are little more than broomsticks. Its \"head\" is an old television screen, flickering with static.")

    show yuxuan happy at left:
        listening_focus
        breathing
    show roboto happy at right:
        listening_focus
        breathing
    with dissolve

    emily_bottom "{cps=30}Pftt... W-What's that?"
    lucas_bottom "{cps=30}Dad... I thought you said the exhibit was filled with inventors..."

    show yuxuan happy at left:
        speaking_focus
        breathing
    yuxuan "{cps=30}I present to you the marvel of modern ingenuity, the pinnacle of technological advancement... ROBOTO!"
    show yuxuan happy at left:
        listening_focus
        breathing
    show roboto happy at right:
        speaking_focus
        breathing
    roboto "{cps=30}H-H-Hello. My name is R-Roboto- I-I-I-...."
    show roboto happy at right:
        listening_focus
        breathing
    lucas_bottom "{cps=30}It talks like it's choking!"

    show yuxuan happy at left:
        speaking_focus
        breathing
    yuxuan "{cps=30}Roboto will revolutionize your life! It can assist with daily chores, answer your questions, and even tell jokes! Observe!"
    show yuxuan happy at left:
        listening_focus
        breathing
    show roboto happy at right:
        speaking_focus
        breathing
    roboto "{cps=30}W-w-w-why did the chicken from Tianho c-c-crossed the road?"
    show roboto happy at right:
        listening_focus
        breathing
    male_1 "{cps=30}Oh I love these types of jokes! Why?"

    show roboto error at right:
        speaking_focus
        breathing
    roboto "{cps=30}I-I-I-I- Error... Error... T-T-T-..."
    show roboto error at right:
        listening_focus
        breathing

    daniel_bottom "{cps=30}Maybe it's speaking in Kyeongjangese?"
    sarah_bottom "{cps=30}Pfttt... Hahaha!"

    show yuxuan happy at left:
        speaking_focus
        breathing
    yuxuan "{cps=30}This is merely a minor adjustment issue! Roboto is fully capable of... of... uh..."
    show yuxuan happy at left:
        listening_focus
        breathing

    show roboto error at right:
        speaking_focus
        breathing
    roboto "{cps=30}T-To get to the o-o-other s-s-s-s-s.... ERROR... ERROR... sideeee.... S-s-s-s-s-"
    show roboto error at right:
        listening_focus
        breathing
    female_1 "{cps=30}W-What's happening?"
    male_2 "{cps=30}Look out! It's gonna explode!"

    show roboto malfunction at right:
        speaking_focus
        breathing
    roboto "{cps=30}BeboOoOot... Bebooot! Bebottt!"

    $ narr("Roboto begins to shake violently, its screen flashing with bright, chaotic patterns. The arms jerk wildly, one of them flying off and clanking somewhere near the crowd. The legs collapse, and the entire contraption falls over with a resounding thud.")

    show yuxuan happy at left:
        speaking_focus
        breathing
    show roboto malfunction at right:
        listening_focus
        breathing
    yuxuan "{cps=30}I uh... um... well-"

    show yuxuan happy at left:
        listening_focus
        breathing

    male_1 "{cps=30}Aww brother this guy stinks!"
    female_1 "{cps=30}Come on! We came here for nothing?"
    male_2 "{cps=30}Tianho will look bad if this man was given a chance to talk to the Kyeongjang Emperor!"

    show yuxuan happy at left:
        speaking_focus
        breathing
    yuxuan "{cps=30}Umm... A minor setback! I'll have Roboto up and running by tomorrow! You'll see!"

    hide yuxuan
    hide roboto
    with dissolve

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    show daniel_kid neutral at topleft:
        xoffset 200
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    with dissolve

    $ narr("The crowd disperses, with some still laughing as they walk along.")

    dorian "{cps=30}Well, he's certainly memorable. I'll give him that. But no way he'll win an audience with the Emperor of Kyeongjang."
    elara "{cps=30}Dorian! That's so mean! What if he actually succeeds one day?"
    dorian "{cps=30}You're not wrong, but sometimes ambition needs a little... refinement."
    elara "{cps=30}And sometimes, it just needs a little time."

    show sarah_kid neutral at topright:
        toggle_flip
        speaking_focus
        breathing
    sarah "{cps=30}I kinda feel bad for him."

    elara "{cps=30}Me too, sweetie."

    show sarah_kid neutral at topright:
        toggle_flip
        listening_focus
        breathing
    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        speaking_focus
        breathing
    emily "{cps=30}Hey Sarah. Maybe you should draw a better version of Roboto for him. He clearly needs help."

    elara "{cps=30}Emily. Be nice."

    show emily_kid neutral at topright:
        toggle_flip
        xoffset -200
        listening_focus
        breathing
    show lucas_kid neutral at topleft:
        speaking_focus
        breathing
    lucas "{cps=30}Dad, can we come back tomorrow? I want to see it break down again!"

    dorian "{cps=30}Be nice, Lucas."

    $ narr("Elara's words echo in my mind, and I sigh. Who knows? Maybe one day, against all odds, Cheng Yuxuan and his glorified talking TV will surprise us all.")

    show lucas_kid neutral at topleft:
        listening_focus
        breathing
    hide daniel_kid
    hide emily_kid
    hide sarah_kid
    show dorian neutral at top:
        xoffset 220
        speaking_focus
        breathing
    show elara neutral at top:
        xoffset -220
        listening_focus
        breathing
    with dissolve

    dorian "{cps=30}Alright, my heart. We've had our fill. Shall we head back to the inn?"

    show dorian neutral at top:
        xoffset 220
        listening_focus
        breathing
    show elara neutral at top:
        xoffset -220
        speaking_focus
        breathing
    elara "{cps=30}Of course, my heart."

    scene bg black_background with long_fade
    $ narr("End of Chapter 1 Part 1.")
    return
